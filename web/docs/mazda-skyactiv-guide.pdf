<div class="embed aem-GridColumn aem-GridColumn--default--12"><div id="embed-55127a9b58" class="cmp-embed">
    
    <style>
footer.experiencefragment.xf-footer {
padding: 0px;
}
.adv-container-xf-footer-links .text {
margin-top: 0;
}
</style>

<script>
(function () {
  const tagFilterLinks = document.querySelectorAll('.cmp-tagfilter.inline .tag-item a');

  if (!tagFilterLinks.length) return;

  tagFilterLinks.forEach(link => {
    try {
      const url = new URL(link.href);
      const pathname = url.pathname;
      const searchTags = url.searchParams.get('search-tags');

      if (!searchTags) return;

      const newPath = pathname.replace(/(list)(\/|\.html)?$/, (_, base, suffix) => {
        if (suffix === '/') {
          return `list.${searchTags}/`;
        } else if (suffix === '.html') {
          return `list.${searchTags}.html`;
        } else {
          return `list.${searchTags}`;
        }
      });

      url.pathname = newPath;
      link.href = url.toString();
    } catch (e) {
      console.warn('Invalid URL in tagFilterLinks:', link.href, e);
    }
  });
})();
</script>
    
</div>

    

</div>
